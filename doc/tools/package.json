{
  "name": "doc-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@vivliostyle/cli": "^7.4.0",
    "markdown-it": "^14.1.1",
    "highlight.js": "^11.11.1",
    "cheerio": "1.0.0-rc.12"
  },
  "scripts": {
    "book:html": "node build-book.mjs",
    "book:pdf": "node run-vivliostyle.mjs build -c vivliostyle.config.cjs",
    "book:preview": "node run-vivliostyle.mjs preview -c vivliostyle.config.cjs",
    "book": "npm run book:html -- ../legacy/css-roadmap.md && npm run book:pdf"
  }
}
